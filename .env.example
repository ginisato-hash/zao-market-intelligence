NODE_ENV=development
LOG_LEVEL=info
ZAO_POSTAL_CODE=990-2301
ZAO_TIMEZONE=Asia/Tokyo

DATABASE_MODE=local
LOCAL_DB_PATH=.data/zao-market-intelligence.sqlite

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_R2_BUCKET=zao-market-screenshots

SCREENSHOT_STORAGE=local
LOCAL_SCREENSHOT_DIR=.data/screenshots
SCREENSHOT_STORAGE_BUCKET=zao-market-intelligence-local

# Per-scheduled-run crawl volume multiplier (cadence unchanged). Default 1 (safe
# baseline). The always-on Mac rotating launchd job sets 3 to ~3x observations
# per run. Clamped to [1, 5]; invalid values fall back to 1.
ZMI_CRAWL_VOLUME_MULTIPLIER=1
