<?xml version="1.0" encoding="UTF-8"?>
<!--
  Phase AUTO-RUNNER16X - launchd template for the rotating 2-hourly market refresh.

  Installed live template for the active rotating market refresh.
  The old 09:00 narrow live job is expected to remain disabled.
  Only one live history writer should be loaded at a time.

  Runs every 2 hours (00,02,...,22 JST). Six live gates + PLANNER_ROTATION_ENABLED
  drive planner-selected slugs/stay_dates. Strict per-run caps are code-defined in
  rotatingCollectionScopePlanner: total 24, booking 12, jalan 12, rakuten 0,
  google 0. Runs every 2 hours, so theoretical max is 288 pages/day. 24h cooldown
  per (source,property,stay_date). Rakuten/Google never collected.
  PUBLISH_CHATGPT_DB=1 publishes to the chatgpt-db-latest release after a
  successful aligned append (publish failure is non-fatal). No pricing/PMS.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.yuge.zmi.market-refresh-rotating</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-lc</string>
		<string>cd /Users/gini/Documents/ZMI/zao-market-intelligence &amp;&amp; ZMI_AUTORUN_ENABLED=1 COLLECT_BOOKING=1 COLLECT_JALAN=1 ALLOW_HISTORY_APPEND=1 HISTORY_TO_DB_SYNC=1 BUILD_AI_CONTEXT=1 PLANNER_ROTATION_ENABLED=1 PUBLISH_CHATGPT_DB=1 ZMI_CRAWL_VOLUME_MULTIPLIER=3 ZMI_NEAR_TERM_DENSE_DAYS=30 npm run auto-runner:market-refresh-rotating</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/gini/Documents/ZMI/zao-market-intelligence</string>
	<key>StandardOutPath</key>
	<string>/Users/gini/Documents/ZMI/zao-market-intelligence/.logs/market-refresh-rotating.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/gini/Documents/ZMI/zao-market-intelligence/.logs/market-refresh-rotating.err.log</string>
	<key>StartCalendarInterval</key>
	<array>
		<dict><key>Hour</key><integer>0</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>2</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>4</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>6</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>14</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
		<dict><key>Hour</key><integer>22</integer><key>Minute</key><integer>0</integer></dict>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<key>KeepAlive</key>
	<false/>
</dict>
</plist>
